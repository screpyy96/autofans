<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AutoFans" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <!-- Dedicated square canvas: unlike the launcher asset, this has the
             full AutoFans wordmark inside Android's mandatory icon safe area. -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_wordmark</item>
        <item name="android:windowSplashScreenBehavior">icon_preferred</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
